# Copy to .env (gitignored). Loaded by `just` (dotenv-load), sqlx-cli, and sqlx macros.

# --- database (ALWAYS required; matches infrastructure/docker/docker-compose.yml) ---
# Host port 5433 because a native PostgreSQL often owns 5432 on dev machines.
DATABASE_URL=postgres://dice:dice_dev@localhost:5433/dice

# --- runtime profile ---
# dev-lite = in-proc bus + memory cache (only Postgres needed)
# full     = NATS bus + Redis cache (run `just infra-up` first)
DICE_PROFILE=dev-lite
# Per-backend overrides (default chosen by DICE_PROFILE):
# DICE_BUS=local|nats
# DICE_CACHE=memory|redis
DICE_REDIS_URL=redis://localhost:6379
DICE_NATS_URL=nats://localhost:4222

# Split mode: 1 routes auth/chat/presence over NATS RPC to standalone service
# bins instead of mounting them in-process (requires DICE_PROFILE=full). Set per
# process by `just split-up`; media + voice always stay in-process. Leave unset
# for the monolith.
# DICE_SPLIT=1

# --- identity / addresses ---
# Snowflake node id (0..=1023). In split mode EACH process MUST use a distinct
# id (gateway 0, auth 1, chat 2, presence 3 — `just split-up` sets these) so
# generated ids never collide.
DICE_NODE_ID=0
DICE_REST_ADDR=0.0.0.0:8443
DICE_QUIC_ADDR=0.0.0.0:8444
# Prometheus /metrics admin port, bound on all interfaces so the dockerized
# Prometheus (`just metrics-up`) can reach it via host.docker.internal; use
# 127.0.0.1 to keep it host-local if you don't run the dashboard. In split mode
# `just split-up` gives each bin a distinct one (gateway 9600, auth 9601, chat
# 9602, presence 9603) so they don't collide; a bin serves /metrics only if set.
DICE_ADMIN_ADDR=0.0.0.0:9600

# --- TLS + JWT keys ---
# In dev profiles the monolith auto-generates these on first boot if missing.
DICE_TLS_CERT=dev/certs/server.crt
DICE_TLS_KEY=dev/certs/server.key
DICE_JWT_PRIVATE_PEM=dev/keys/jwt_ed25519.pem
DICE_JWT_PUBLIC_PEM=dev/keys/jwt_ed25519.pub.pem

# --- media (attachments) ---
# Local-fs object store root (dev). Created on first upload. An S3/rustls
# backend is the future seam; MinIO deferred.
DICE_MEDIA_DIR=data/media

# --- client-side (consumed by `just client`) ---
# DICE_DEV_CA=dev/certs/dev-ca.pem
# DICE_API_URL=https://localhost:8443
# DICE_GATEWAY_QUIC=localhost:8444
# DICE_GATEWAY_WSS=wss://localhost:8443/gateway/v1

# --- logging ---
RUST_LOG=info,dice=debug

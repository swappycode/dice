// The Dice theme system — the native equivalent of the prototype's 8
// `[data-theme]` CSS-var blocks. Every value is transcribed verbatim from
// `Dice.dc.html`. A `Palette` is the 24-token contract; `Theme.p` is the
// active one, selected by `Theme.id` (0..7) set from Rust.
//
// Fidelity/perf note (per the user's "build lean" directive): translucent
// surface tokens keep their alpha so layered panels read as "glass" over the
// desk gradient WITHOUT any real backdrop blur. Desk radial gradients are
// centered (Slint has no off-center radial) — a deliberate, invisible
// simplification.

// brush  -> may be a gradient (desk / titlebar / accent-grad)
// color  -> a solid (often translucent) fill or ink
export struct Palette {
    desk: brush,
    win: color,
    win-solid: color,
    rail: color,
    panel: color,
    panel2: color,
    titlebar: brush,
    field: color,
    border: color,
    border-lt: color,
    text: color,
    muted: color,
    subtle: color,
    accent: color,
    accent2: color,
    accent-grad: brush,
    accent-ink: color,
    sel: color,
    hover: color,
    glow: color,
    online: color,
    idle: color,
    dnd: color,
    offline: color,
}

export global Theme {
    in property <int> id: 0;

    property <[Palette]> palettes: [
        // 0 ── midnight (hero) — deep indigo Aero glass
        {
            desk: @radial-gradient(circle, #222e63 0%, #10162f 48%, #070a16 100%),
            win: #10162f.with-alpha(0.72),
            win-solid: #0f1430,
            rail: #090d1e.with-alpha(0.5),
            panel: #121936.with-alpha(0.46),
            panel2: #0b1024.with-alpha(0.32),
            titlebar: @linear-gradient(180deg, #6080e8.with-alpha(0.40) 0%, #263474.with-alpha(0.28) 100%),
            field: #070a1a.with-alpha(0.62),
            border: #7a98ff.with-alpha(0.16),
            border-lt: #ffffff.with-alpha(0.09),

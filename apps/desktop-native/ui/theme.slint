            border-lt: #ffffff.with-alpha(0.08),
            text: #efe6ff,
            muted: #b9a6e6,
            subtle: #7e6bab,
            accent: #a78bfa,
            accent2: #e879f9,
            accent-grad: @linear-gradient(135deg, #a78bfa, #e879f9),

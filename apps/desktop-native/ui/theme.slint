        // 3 ── bubble — pink pastel
        {
            desk: @radial-gradient(circle, #ffe3f1 0%, #ffbfdf 50%, #ff93c6 100%),
            win: #fff4fa.with-alpha(0.64),
            win-solid: #fff2f8,

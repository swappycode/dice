            win-solid: #1c0e07,
            rail: #180b06.with-alpha(0.55),
            panel: #30180e.with-alpha(0.46),
            panel2: #1a0c07.with-alpha(0.34),
            titlebar: @linear-gradient(180deg, #ff8c3c.with-alpha(0.3) 0%, #8c3c14.with-alpha(0.24) 100%),

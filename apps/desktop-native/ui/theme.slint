            border: #ff965a.with-alpha(0.18),
            border-lt: #ffffff.with-alpha(0.08),
            text: #ffe8d6,
            muted: #e0a982,
            subtle: #a8745a,
            accent: #ff8a3c,
            accent2: #ff5c4a,
            accent-grad: @linear-gradient(135deg, #ff8a3c, #ff5c4a),
            accent-ink: #2a0f04,
            sel: #ff8a3c.with-alpha(0.16),
            hover: #ffffff.with-alpha(0.05),
            glow: #ff5c4a.with-alpha(0.30),
            online: #5ad17e,
            idle: #ffc24b,
            dnd: #ff5c4a,
            offline: #8a6a5a,
        },
    ];

    out property <Palette> p: palettes[root.id];

    out property <string> name:
        root.id == 0 ? "midnight" : root.id == 1 ? "aero" :
        root.id == 2 ? "phosphor" : root.id == 3 ? "bubble" :
        root.id == 4 ? "luna"     : root.id == 5 ? "nocturne" :
        root.id == 6 ? "vantablack" : "ember";

    // presence kind (0 online, 1 idle, 2 dnd, 3 offline) → theme color
    pure public function presence-color(k: int) -> color {
        return k == 0 ? root.p.online : k == 1 ? root.p.idle : k == 2 ? root.p.dnd : root.p.offline;
    }
}

// Geometry tokens — theme-invariant sizes/radii (the prototype's layout px).
export global Geo {
    out property <length> titlebar-h: 42px;
    out property <length> statusbar-h: 26px;
    out property <length> rail-w: 66px;
    out property <length> channels-w: 236px;
    out property <length> members-w: 208px;
    out property <length> header-h: 48px;

    out property <length> r-window: 16px;
    out property <length> r-card: 14px;
    out property <length> r-row: 8px;
    out property <length> r-input: 9px;
    out property <length> r-button: 10px;
}

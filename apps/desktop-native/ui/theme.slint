            win: #ffffff.with-alpha(0.58),
            win-solid: #eef4fb,
            rail: #ffffff.with-alpha(0.42),
            panel: #ffffff.with-alpha(0.46),
            panel2: #ffffff.with-alpha(0.34),
            titlebar: @linear-gradient(180deg, #ffffff.with-alpha(0.9) 0%, #cee4fa.with-alpha(0.6) 100%),
            field: #ffffff.with-alpha(0.72),
            border: #366caa.with-alpha(0.26),
            border-lt: #ffffff.with-alpha(0.75),
            text: #102438,
            muted: #3c5e80,
            subtle: #6f8aa6,
            accent: #1f7ae0,
            accent2: #37b8ff,
            accent-grad: @linear-gradient(135deg, #1f7ae0, #37b8ff),
            accent-ink: #ffffff,
            sel: #1f7ae0.with-alpha(0.16),

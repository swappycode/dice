            border: #ffffff.with-alpha(0.1),
            border-lt: #ffffff.with-alpha(0.06),
            text: #f0f0f2,
            muted: #8a8a92,
            subtle: #56565e,
            accent: #46e0ff,
            accent2: #8ad8ff,

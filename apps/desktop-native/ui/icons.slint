// Vector icons via Slint `Path` (SVG command strings) — no raster assets, crisp
// at any size + theme-colored. 24×24 viewbox to match the prototype's SVGs.
import { Theme } from "theme.slint";

export component Icon inherits Path {
    in property <length> size: 16px;
    in property <brush> stroke-color: Theme.p.muted;
    in property <brush> fill-color: transparent;
    in property <length> sw: 1.6px;
    width: size;
    height: size;
    viewbox-width: 24;
    viewbox-height: 24;
    stroke: stroke-color;
    stroke-width: sw;
    fill: fill-color;
}

// stroke icons (outline)
export component IcoMinimize inherits Icon { commands: "M5 12 L19 12"; }
export component IcoMaximize inherits Icon { commands: "M4.5 4.5 L19.5 4.5 L19.5 19.5 L4.5 19.5 Z"; }
export component IcoClose inherits Icon { commands: "M6 6 L18 18 M18 6 L6 18"; }
export component IcoChevron inherits Icon { commands: "M6 9 L12 15 L18 9"; }
export component IcoSearch inherits Icon { commands: "M11 18 A7 7 0 1 1 11.001 4 A7 7 0 0 1 11 18 Z M16.5 16.5 L21 21"; }
export component IcoPlus inherits Icon { commands: "M12 5 L12 19 M5 12 L19 12"; }
export component IcoGear inherits Icon {
    commands: "M12 9 A3 3 0 1 1 11.999 15 A3 3 0 0 1 12 9 Z M12 2 L12 5 M12 19 L12 22 M2 12 L5 12 M19 12 L22 12 M5 5 L7 7 M17 17 L19 19 M19 5 L17 7 M7 17 L5 19";
}

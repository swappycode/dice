    fill-color: Theme.p.text;
    sw: 0px;
    commands: "M6.5 10.8 C7.8 13.4 9.9 15.5 12.5 16.8 L14.5 14.8 C14.8 14.5 15.2 14.4 15.5 14.6 C16.6 15 17.8 15.2 19 15.2 C19.6 15.2 20 15.6 20 16.2 L20 19.5 C20 20.1 19.6 20.5 19 20.5 C10.7 20.5 4 13.8 4 5.5 C4 4.9 4.4 4.5 5 4.5 L8.3 4.5 C8.9 4.5 9.3 4.9 9.3 5.5 C9.3 6.7 9.5 7.9 9.9 9 C10 9.3 9.9 9.7 9.6 10 Z";

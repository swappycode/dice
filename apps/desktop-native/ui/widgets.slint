// Reusable vector primitives. All generated — no raster assets (per the brief).
// Deliberately no drop-shadow-blur (software-renderer + perf): the look comes
// from fills, gradients and 1px borders.
import { Theme } from "theme.slint";

// Text presets so the bundled fonts get used without repeating font-family.
// Display = Chakra Petch (headings, wordmark); Mono = Space Mono (status/codes).
export component Display inherits Text { font-family: "Chakra Petch"; }
export component Mono inherits Text { font-family: "Space Mono"; }

// The Dice die mark: rounded square + top gloss + 5 white pips (quincunx).
// Scales by `size`; pip/gloss positions follow the prototype's 100-unit viewbox.
export component DieLogo inherits Rectangle {
    in property <length> size: 60px;
    in property <color> face: Theme.p.accent;
    in property <color> pip: #ffffff;
    in property <bool> gloss: true;
    property <length> u: size / 100;
    width: size;
    height: size;

    Rectangle {
        x: 8 * u; y: 8 * u; width: 84 * u; height: 84 * u;
        border-radius: 22 * u;
        background: face;
    }
    if gloss : Rectangle {
        x: 8 * u; y: 8 * u; width: 84 * u; height: 38 * u;
        border-radius: 19 * u;
        background: #ffffff.with-alpha(0.24);
    }
    Rectangle { x: 22 * u; y: 22 * u; width: 16 * u; height: 16 * u; border-radius: 8 * u; background: pip; }
    Rectangle { x: 62 * u; y: 22 * u; width: 16 * u; height: 16 * u; border-radius: 8 * u; background: pip; }
    Rectangle { x: 42 * u; y: 42 * u; width: 16 * u; height: 16 * u; border-radius: 8 * u; background: pip; }
    Rectangle { x: 22 * u; y: 62 * u; width: 16 * u; height: 16 * u; border-radius: 8 * u; background: pip; }
    Rectangle { x: 62 * u; y: 62 * u; width: 16 * u; height: 16 * u; border-radius: 8 * u; background: pip; }
}

// Generated avatar / guild tile: a per-entity colored rounded square + initials.
export component Avatar inherits Rectangle {
    in property <length> size: 38px;
    in property <color> tint: #5b8cff;
    in property <string> initials: "FF";
    in property <color> ink: #0b1020;
    in property <length> radius: size * 0.31;
    width: size;
    height: size;
    border-radius: radius;
    background: tint;
    Text {
        text: initials;
        color: ink;
        font-size: size * 0.34;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
}

// A rounded accent fill for buttons/badges. IMPORTANT: the software renderer
// rounds SOLID color fills but NOT gradients OR clipped children — both render
// as hard squares. So accent surfaces use a solid color; set `border-radius` +
// size + content on the GradFill itself, and override `fill` for non-accent
// tints (e.g. the red hang-up button). The brief's gradients are reserved for
// large non-rounded areas (the desk, the login top strip).
export component GradFill inherits Rectangle {
    in property <color> fill: Theme.p.accent;
    background: fill;
}

// Vertical scroll area with a THEME-COLORED thumb and NO visible track (the std
// ScrollView's scrollbar ignores our palette and draws a track). Wheel + drag-on-
// content scroll via Flickable; the thumb/track is also draggable to scrub.
export component VScroll inherits Rectangle {
    clip: true;
    fl := Flickable {
        viewport-width: self.width;
        @children
    }
    track := Rectangle {
        property <length> trk: root.height;
        property <length> vp: max(fl.viewport-height, 1px);
        visible: fl.viewport-height > root.height + 2px;
        x: root.width - self.width - 2px;
        width: 8px;
        thumb := Rectangle {
            width: 5px;
            x: (parent.width - self.width) / 2;
            height: max(32px, track.trk * track.trk / track.vp);
            y: (track.trk - self.height) * (-fl.viewport-y / max(track.vp - track.trk, 1px));
            border-radius: self.width / 2;
            background: ta.has-hover || ta.pressed ? Theme.p.accent : Theme.p.accent.with-alpha(0.6);
        }
        ta := TouchArea {
            moved => {
                fl.viewport-y = -clamp((self.mouse-y - thumb.height / 2) / max(track.trk - thumb.height, 1px), 0, 1) * (track.vp - track.trk);
            }
        }
    }
}

// Solid push-button — filled, never hollow/outlined. variant: "primary" (accent
// fill + ink text), "secondary" (tonal accent-tint fill + text), "danger" (red).
export component Btn inherits Rectangle {
    in property <string> label;
    in property <string> variant: "secondary";
    callback clicked;
    height: 42px;
    border-radius: 10px;
    background:
        root.variant == "primary" ? (ta.has-hover ? Theme.p.accent.darker(0.12) : Theme.p.accent) :
        root.variant == "danger" ? (ta.has-hover ? Theme.p.dnd.darker(0.10) : Theme.p.dnd) :
        (ta.has-hover ? Theme.p.accent.with-alpha(0.30) : Theme.p.accent.with-alpha(0.16));
    Text {
        text: root.label;
        color: root.variant == "primary" ? Theme.p.accent-ink : root.variant == "danger" ? #ffffff : Theme.p.text;
        font-size: 13px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// Presence status dot with the punch-out ring (no blur; the ring reads it out).
export component PresenceDot inherits Rectangle {
    in property <color> tint: Theme.p.online;
    in property <color> ring: Theme.p.win-solid;
    in property <length> size: 12px;
    width: size;
    height: size;
    border-radius: size / 2;
    background: tint;
    border-width: 2.5px;
    border-color: ring;
}

import { Theme, Geo } from "theme.slint";
import { DieLogo, Display, GradFill } from "widgets.slint";
import { State } from "state.slint";
import { IcoMinimize, IcoMaximize, IcoClose } from "icons.slint";

component LoginField inherits Rectangle {
    in property <string> value;
    in property <bool> password: false;
    height: 42px;
    border-radius: Geo.r-input;
    background: Theme.p.field;
    border-width: 1px;
    border-color: Theme.p.border;
    HorizontalLayout {
        padding-left: 13px;
        padding-right: 13px;
        TextInput {
            text: value;
            color: Theme.p.text;
            font-size: 13px;
            vertical-alignment: center;
            single-line: true;
            input-type: password ? InputType.password : InputType.text;
        }
    }
}

// A clickable text link (subtle → accent on hover). Used for the auth footers.
component Link inherits Rectangle {
    in property <string> text;
    callback clicked;
    width: t.preferred-width;
    t := Text {
        text: root.text;
        color: ta.has-hover ? Theme.p.accent : Theme.p.subtle;
        font-size: 11.5px;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

// The three frameless window buttons (min / max / close). Shared by the app
// title bar and the login/register chrome (exported for shell.slint).
export component WinControls inherits HorizontalLayout {
    spacing: 4px;
    Rectangle {
        width: 26px; height: 26px; border-radius: 7px;
        background: mn.has-hover ? Theme.p.hover : transparent;
        IcoMinimize { size: 14px; stroke-color: Theme.p.muted; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
        mn := TouchArea { clicked => { State.win-minimize(); } }
    }
    Rectangle {
        width: 26px; height: 26px; border-radius: 7px;
        background: mx.has-hover ? Theme.p.hover : transparent;
        IcoMaximize { size: 12px; stroke-color: Theme.p.muted; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
        mx := TouchArea { clicked => { State.win-maximize(); } }
    }
    Rectangle {
        width: 26px; height: 26px; border-radius: 7px;
        background: cl.has-hover ? Theme.p.dnd : transparent;
        IcoClose { size: 13px; stroke-color: cl.has-hover ? #ffffff : Theme.p.muted; x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
        cl := TouchArea { clicked => { State.win-close(); } }
    }
}

// A theme cycler pill: an accent swatch + the current theme name; click advances
// to the next of the 8 palettes. Lets the login screen change themes (the full
// builder lives in the app's Theme dialog).
export component ThemePill inherits Rectangle {
    height: 26px;
    width: row.preferred-width;
    border-radius: 13px;
    background: ta.has-hover ? Theme.p.hover : transparent;
    row := HorizontalLayout {
        padding-left: 9px;
        padding-right: 12px;
        spacing: 7px;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 12px; height: 12px; border-radius: 6px;
                background: Theme.p.accent;
                border-width: 1px; border-color: Theme.p.border-lt;
            }
        }
        Display { text: Theme.name; color: Theme.p.muted; font-size: 11.5px; font-weight: 600; vertical-alignment: center; }
    }
    ta := TouchArea { clicked => { Theme.id = Theme.id >= 7 ? 0 : Theme.id + 1; } }
}

// Shared wallpaper frame for the auth screens: centers its card and lays a top
// chrome strip (drag handle + theme cycler + window controls) over it. The login
// flow has no app title bar, so this strip is the window's only chrome.
component AuthFrame inherits Rectangle {
    background: transparent;

    VerticalLayout {
        alignment: center;
        HorizontalLayout { alignment: center; @children }
    }

    // top chrome strip — sits above the (vertically-centered) card; they never overlap
    Rectangle {
        y: 0;
        height: 42px;
        // drag handle behind the controls: a press hands off to the OS move-loop
        TouchArea {
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                    State.win-drag();
                }
            }
        }
        HorizontalLayout {
            padding-left: 10px;
            padding-right: 8px;
            VerticalLayout { alignment: center; ThemePill { } }
            Rectangle { horizontal-stretch: 1; }
            VerticalLayout { alignment: center; WinControls { } }
        }
    }
}

// Shared glass card: 380px rounded panel with the accent top strip. Built from
// SOLID fills only (the software renderer rounds solid border-radius but not
// gradients/clip): a solid-accent base card rounds all four corners, then a
// win-colored body cover from y=7 down — rounded at the BOTTOM only — leaves the
// top 7px showing as the accent strip with corners that follow the card.
component AuthCard inherits Rectangle {
    width: 380px;
    border-radius: Geo.r-window;
    background: Theme.p.accent;
    border-width: 1px;
    border-color: Theme.p.border-lt;
    Rectangle {
        y: 7px;
        width: 100%;
        height: parent.height - 7px;
        background: Theme.p.win-solid;
        border-bottom-left-radius: Geo.r-window;
        border-bottom-right-radius: Geo.r-window;
    }
    VerticalLayout {
        padding-top: 41px;
        padding-left: 34px;
        padding-right: 34px;
        padding-bottom: 30px;
        spacing: 10px;
        @children
    }
}

// ── Sign-in ──
export component LoginScreen inherits AuthFrame {
    AuthCard {
        HorizontalLayout {
            alignment: center;
            DieLogo { size: 60px; }
        }
        Display {
            text: "DICE";
            color: Theme.p.text;
            font-size: 34px;
            font-weight: 700;
            letter-spacing: 7px;
            horizontal-alignment: center;
        }
        Text {
            text: "self-hosted chat & voice that never phones home";
            color: Theme.p.muted;
            font-size: 12px;
            horizontal-alignment: center;
        }

        Rectangle { height: 6px; }

        LoginField { value: "fanless_fred"; }
        LoginField { value: "supersecret"; password: true; }

        // SIGN IN (solid accent fill so the rounded corners render)
        GradFill {
            height: 44px;
            border-radius: Geo.r-button;
            Display {
                text: "SIGN IN";
                color: Theme.p.accent-ink;
                font-size: 14px;
                font-weight: 700;
                letter-spacing: 1px;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: 100%;
                height: 100%;
            }
            TouchArea { clicked => { State.screen = 1; } }
        }

        HorizontalLayout {
            Link { text: "Create account"; clicked => { State.screen = 2; } }
            Rectangle { horizontal-stretch: 1; }
            Link { text: "Forgot password?"; }
        }
    }
}

// ── Create account ──
export component RegisterScreen inherits AuthFrame {
    AuthCard {
        HorizontalLayout {
            alignment: center;
            DieLogo { size: 52px; }
        }
        Display {
            text: "CREATE ACCOUNT";
            color: Theme.p.text;
            font-size: 21px;
            font-weight: 700;
            letter-spacing: 3px;
            horizontal-alignment: center;
        }
        Text {
            text: "join your self-hosted Dice server";
            color: Theme.p.muted;
            font-size: 12px;
            horizontal-alignment: center;
        }

        Rectangle { height: 4px; }

        LoginField { value: "fanless_fred"; }
        LoginField { value: "fred@rack.local"; }
        LoginField { value: "supersecret"; password: true; }
        LoginField { value: "supersecret"; password: true; }

        // CREATE ACCOUNT
        GradFill {
            height: 44px;
            border-radius: Geo.r-button;
            Display {
                text: "CREATE ACCOUNT";
                color: Theme.p.accent-ink;
                font-size: 14px;
                font-weight: 700;
                letter-spacing: 1px;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: 100%;
                height: 100%;
            }
            TouchArea { clicked => { State.screen = 1; } }
        }

        HorizontalLayout {
            alignment: center;
            Link { text: "← Back to sign in"; clicked => { State.screen = 0; } }
        }
    }
}
